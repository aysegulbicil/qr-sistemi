# database.default.database = qr_sistemi
# database.default.username = qr_user
# database.default.password = qr_pass
# database.default.DBDriver = MySQLi
# database.default.port     = 3306

#=== Docker Compose port / parola override (istege bagli) ====
# WEB_PORT=8090
# DB_PORT=3307
# PMA_PORT=8091
# DB_NAME=qr_sistemi
# DB_USER=qr_user
# DB_PASSWORD=qr_pass
# DB_ROOT_PASSWORD=root_pass
