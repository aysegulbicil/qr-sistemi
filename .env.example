#-------------------------------------------------------------
# qr-sistemi - ornek ortam degiskenleri
# Kullanim:  cp .env.example .env
#
# NOT: Bu dosya hem CodeIgniter 4 (.env) hem de Docker Compose
# tarafindan okunabilir. Compose, kullanmadigi satirlari yok sayar.
#-------------------------------------------------------------

#=== CodeIgniter 4 ===========================================
CI_ENVIRONMENT = development
app.baseURL = 'http://localhost:8090/'

#=== Veritabani (db profili acildiginda ac) ==================
