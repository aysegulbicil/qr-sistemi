#-------------------------------------------------------------
# qr-sistemi - ornek ortam degiskenleri
# Kullanim:  cp .env.example .env
#
# NOT: Bu dosya hem CodeIgniter 4 (.env) hem de Docker Compose
# tarafindan okunabilir. Compose, kullanmadigi satirlari yok sayar.
#-------------------------------------------------------------

#=== CodeIgniter 4 ===========================================
CI_ENVIRONMENT = development
app.baseURL ='http://192.168.1.104:8090/'
app.indexPage = ''
app.appTimezone = 'Europe/Istanbul'

#=== Ozellik bayraklari (satis paketi) =======================
# Dinamik QR paketi satildiysa acin. Bos/yorum birakirsaniz sadece Sabit QR.
# feature.qrDynamic = true

#=== Database (enabled) ======================================
database.default.hostname = db
database.default.database = qr_sistemi
database.default.username = qr_user
database.default.password = qr_pass
database.default.DBDriver = MySQLi
database.default.port = 3306

#=== Docker Compose port / parola override (istege bagli) ====
# WEB_PORT=8090
# DB_PORT=3307
# PMA_PORT=8091
# DB_NAME=qr_sistemi
# DB_USER=qr_user
# DB_PASS